{
  "name": "open-harness",
  "version": "0.1.0",
  "private": true,
  "description": "Open Harness — AI Agent Sandbox Orchestrator",
  "packageManager": "pnpm@10.12.1",
  "scripts": {
    "setup": "pnpm install && pnpm -r run build && pnpm link --global ./cli",
    "build": "pnpm -r run build",
    "test": "pnpm -r run test",
    "lint": "pnpm -r run lint",
    "format:check": "pnpm -r run format:check",
    "format": "pnpm -r run format",
    "docs:dev": "pnpm --filter @openharness/docs dev",
    "docs:build": "pnpm --filter @openharness/docs build"
  },
  "devDependencies": {
    "vitest": "^3.0.0"
  },
  "engines": {
    "node": ">=20.0.0"
  }
}
