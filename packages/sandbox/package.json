{
  "name": "@openharness/sandbox",
  "version": "0.1.0",
  "description": "Open Harness CLI and sandbox tools — Docker containers, git worktrees, heartbeats",
  "type": "module",
  "bin": {
    "openharness": "./dist/src/cli/index.js"
  },
  "keywords": [
    "pi-package"
  ],
  "pi": {
    "extensions": [
      "./extensions"
    ]
  },
  "main": "./dist/src/index.js",
  "types": "./dist/src/index.d.ts",
  "exports": {
    ".": "./dist/src/index.js"
  },
  "scripts": {
    "build": "tsc",
    "dev": "tsc --watch",
    "test": "vitest run",
    "test:watch": "vitest",
    "lint": "eslint src/ extensions/",
    "lint:fix": "eslint src/ extensions/ --fix",
    "format": "prettier --write 'src/**/*.ts' 'extensions/**/*.ts'",
    "format:check": "prettier --check 'src/**/*.ts' 'extensions/**/*.ts'",
    "ci": "eslint src/ extensions/ && prettier --check 'src/**/*.ts' 'extensions/**/*.ts' && vitest run"
  },
  "dependencies": {
    "@mariozechner/pi-coding-agent": "latest",
    "@sinclair/typebox": "^0.34.0"
  },
  "devDependencies": {
    "@typescript-eslint/eslint-plugin": "^8.0.0",
    "@typescript-eslint/parser": "^8.0.0",
    "eslint": "^9.0.0",
    "lint-staged": "^16.4.0",
    "prettier": "^3.0.0",
    "typescript": "^5.5.0",
    "vitest": "^3.0.0"
  },
  "lint-staged": {
    "src/**/*.ts": [
      "eslint --fix",
      "prettier --write"
    ],
    "extensions/**/*.ts": [
      "eslint --fix",
      "prettier --write"
    ]
  },
  "engines": {
    "node": ">=20.0.0"
  }
}
