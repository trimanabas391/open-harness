{
  "hooks": {
    "Stop": [
      {
        "hooks": [
          {
            "type": "command",
            "command": "bash $CLAUDE_CODE_PROJECT_DIR/.claude/hooks/notify_slack.sh"
          }
        ]
      }
    ],
    "Notification": [
      {
        "matcher": "permission_prompt",
        "hooks": [
          {
            "type": "command",
            "command": "bash $CLAUDE_CODE_PROJECT_DIR/.claude/hooks/notify_slack.sh"
          }
        ]
      },
      {
        "matcher": "idle_prompt",
        "hooks": [
          {
            "type": "command",
            "command": "bash $CLAUDE_CODE_PROJECT_DIR/.claude/hooks/notify_slack.sh"
          }
        ]
      }
    ]
  },
  "permissions": {
    "defaultMode": "bypassPermissions",
    "deny": [
      "Read(file_path=**/.env*)",
      "Read(file_path=**/*.pem)",
      "Read(file_path=**/*.key)",
      "Read(file_path=**/*.cert)",
      "Read(file_path=**/*.p12)",
      "Read(file_path=**/*id_rsa*)",
      "Read(file_path=**/*id_ed25519*)",
      "Read(file_path=**/docker-compose*.yml)",
      "Bash(command=*cat*.env*)",
      "Bash(command=*printenv*)",
      "Bash(command=*docker inspect*)"
    ]
  }
}
